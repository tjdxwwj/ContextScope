# ContextScope Independent Server Configuration

# 启用独立服务模式（true/false）
ENABLE_INDEPENDENT_SERVER=true

# 独立服务器地址
CONTEXTSCOPE_SERVER_URL=http://localhost:18790

# 服务器端口
PORT=18790

# 数据存储目录
CONTEXTSCOPE_WORKSPACE=C:/Users/your-username/.openclaw/contextscope

# 最大存储请求数
MAX_REQUESTS=10000

# 数据保留天数
RETENTION_DAYS=7
