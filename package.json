{
  "name": "openclaw-contextscope",
  "version": "0.0.1",
  "description": "ContextScope - visualize API requests, prompts, and token usage",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "build:all": "npm run build:frontend && npm run build:backend && npm run copy:frontend",
    "build:backend": "tsc",
    "build:frontend": "cd frontend && npm run build",
    "copy:frontend": "node -e \"const fs=require('fs'), path=require('path'); const src='frontend/dist', dest='dist/frontend'; if(fs.existsSync(dest)) fs.rmSync(dest,{recursive:true}); fs.cpSync(src,dest,{recursive:true}); console.log('Copied frontend/dist to dist/frontend');\" ",
    "dev": "tsc --watch",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:frontend\"",
    "start:server": "node dist/src/server.js",
    "dev:server": "node --watch dist/src/server.js",
    "test": "vitest",
    "preview": "cd frontend && npm run preview"
  },
  "dependencies": {
    "openclaw": "^2026.3.13",
    "tiktoken": "^1.0.22"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^9.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "contextscope",
    "api-monitoring",
    "token-usage",
    "prompt-analysis",
    "request-analysis",
    "llm-analytics"
  ],
  "author": "ContextScope Contributors",
  "license": "MIT"
}
