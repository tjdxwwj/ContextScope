{
  "name": "contextscope",
  "version": "1.0.0",
  "description": "ContextScope - visualize API requests, prompts, and token usage",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "scripts": {
    "build": "tsc",
    "build:all": "npm run build:frontend && npm run build:backend",
    "build:backend": "tsc",
    "build:frontend": "cd frontend && npm run build",
    "dev": "tsc --watch",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:frontend\"",
    "test": "vitest",
    "preview": "cd frontend && npm run preview"
  },
  "dependencies": {
    "openclaw": "^2026.3.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^9.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "contextscope",
    "api-monitoring",
    "token-usage",
    "prompt-analysis",
    "request-analysis",
    "llm-analytics"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourname/contextscope"
  }
}
