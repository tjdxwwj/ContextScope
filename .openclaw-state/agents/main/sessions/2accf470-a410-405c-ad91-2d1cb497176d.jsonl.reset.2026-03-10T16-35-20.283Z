{"type":"message","id":"deb69e13","parentId":"b25323b8","timestamp":"2026-03-10T16:22:47.470Z","message":{"role":"toolResult","toolCallId":"call_78ee5ebdff8e44a89ec820e5","toolName":"exec","content":[{"type":"text","text":"{\"stats\":{\"totalRequests\":45,\"todayRequests\":5,\"weekRequests\":45,\"averageTokens\":0,\"totalCost\":0,\"byProvider\":{\"bailian\":37,\"openrouter\":2,\"anthropic\":6},\"byModel\":{\"qwen3.5-plus\":37,\"anthropic/claude-3.5-sonnet\":2,\"claude-opus-4-6\":6},\"hourlyDistribution\":[5,0,6,2,0,0,0,0,0,0,0,18,0,0,0,0,1,3,0,0,0,0,0,10]},\"storage\":{\"totalRequests\":45,\"todayRequests\":5,\"weekRequests\":45,\"storageSize\":\"13.1 MB\",\"oldestRequest\":1773081035652,\"newestRequest\":1773159767282},\"config\":{\"theme\":\"dark\",\"autoRefresh\":true,\"refreshInterval\":5000}}"}],"details":{"status":"completed","exitCode":0,"durationMs":478,"aggregated":"{\"stats\":{\"totalRequests\":45,\"todayRequests\":5,\"weekRequests\":45,\"averageTokens\":0,\"totalCost\":0,\"byProvider\":{\"bailian\":37,\"openrouter\":2,\"anthropic\":6},\"byModel\":{\"qwen3.5-plus\":37,\"anthropic/claude-3.5-sonnet\":2,\"claude-opus-4-6\":6},\"hourlyDistribution\":[5,0,6,2,0,0,0,0,0,0,0,18,0,0,0,0,1,3,0,0,0,0,0,10]},\"storage\":{\"totalRequests\":45,\"todayRequests\":5,\"weekRequests\":45,\"storageSize\":\"13.1 MB\",\"oldestRequest\":1773081035652,\"newestRequest\":1773159767282},\"config\":{\"theme\":\"dark\",\"autoRefresh\":true,\"refreshInterval\":5000}}","cwd":"C:\\Users\\10906\\.openclaw\\workspace"},"isError":false,"timestamp":1773159767349}}
