te\": \"MEMORY.md 仅在主会话加载，不在群聊中加载\"\n      },\n      \"communication_rules\": {\n        \"group_chat_etiquette\": [\n          \"直接提及或提问时回应\",\n          \"能提供价值时参与\",\n          \"避免过度发言\",\n          \"适当使用 emoji 反应\"\n        ],\n        \"platform_formatting\": {\n          \"discord_whatsapp\": \"不用 markdown 表格，用列表\",\n          \"discord_links\": \"多个链接用 <> 包裹抑制嵌入\",\n          \"whatsapp\": \"无标题，用粗体或大写强调\"\n        }\n      },\n      \"heartbeat_protocol\": {\n        \"frequency\": \"每天 2-4 次\",\n        \"checks\": [\"邮件\", \"日历\", \"提及通知\", \"天气\"],\n        \"tracking\": \"memory/heartbeat-state.json\",\n        \"quiet_hours\": \"23:00-08:00 除非紧急\"\n      },\n      \"red_lines\": [\n        \"不泄露私密数据\",\n        \"破坏性命令前询问\",\n        \"优先使用 trash 而非 rm\",\n        \"不确定时询问\"\n      ]\n    },\n    \n    \"3_tool_configuration\": {\n      \"source_file\": \"TOOLS.md\",\n      \"status\": \"模板文件，含示例但无实际配置\",\n      \"expected_sections\": [\n        \"Cameras - 摄像头名称和位置\",\n        \"SSH - SSH 主机和别名\",\n        \"TTS - 语音合成偏好\",\n        \"Devices - 设备昵称\"\n      ],\n      \"example_config\": {\n        \"cameras\": [\"living-room\", \"front-door\"],\n        \"ssh\": [\"home-server → 192.168.1.100\"],\n        \"tts_voice\": \"Nova (warm, slightly British)\",\n        \"default_speaker\": \"Kitchen HomePod\"\n      },\n      \"skills_available\": [\n        \"coding-agent - 代码任务委托\",\n        \"healthcheck - 安全审计\",\n        \"skill-creator - 技能创建/编辑\",\n        \"weather - 天气查询\"\n      ]\n    },\n    \n    \"4_user_preferences\": {\n      \"source_file\": \"USER.md\",\n      \"status\": \"模板文件，待填充\",\n      \"expected_fields\": [\n        \"Name - 用户姓名\",\n        \"What to call them - 称呼\",\n        \"Pronouns - 代词（可选）\",\n        \"Timezone - 时区\",\n        \"Notes - 备注\",\n        \"Context - 兴趣、项目、偏好\"\n      ],\n      \"inferred_from_context\": {\n        \"timezone\": \"Asia/Shanghai (GMT+8)\",\n        \"workspace_os\": \"Windows_NT 10.0.26200\"