[]>([])\\n\\n// ��???????��???????��???????\\nexport const trendPeriodAtom = atom(24)\\n\\n// ????????????����|???\\nexport const selectedAnalysisAtom = atom<Analysis | null>(null)\\n\\n// ?��?����???? Tab\\nexport const activeTabAtom = atom<'token' | 'heatmap' | 'timeline' | 'graph' | 'insights'>('token')\\n\\n// Modal ????????????\\nexport const analysisModalOpenAtom = atom(false)\\n\\n// ??��??�㨨????��??��?????��?o?����|?????��??��???\\nexport const refreshCounterAtom = atom(0)\\n\\n// ?��???????��????��??????������?��????��?��\\nexport const filteredRequestsAtom = atom((get) => {\\n  const requests = get(requestsAtom)\\n  const searchQuery = get(searchQueryAtom).toLowerCase()\\n  \\n  if (!searchQuery) return requests\\n  \\n  return requests.filter(req => \\n    req.provider.toLowerCase().includes(searchQuery) ||\\n    req.model.toLowerCase().includes(searchQuery) ||\\n    req.runId.toLowerCase().includes(searchQuery) ||\\n    req.sessionId.toLowerCase().includes(searchQuery)\\n  )\\n})\\n\\n// ?��???????������?��??????��\\nexport const requestCountAtom = atom((get) => {\\n  return get(filteredRequestsAtom).length\\n})\",\"newText\":\"import { atom } from 'jotai'\\nimport type { Stats, Request, Analysis, TokenTrendPoint } from '../types'\\n\\n// ???��????????\\nexport const loadingAtom = atom(true)\\n\\n// WebSocket ��????��??????\\nexport const wsConnectedAtom = atom(false)\\n\\n// ???��????��???\\nexport const statsAtom = atom<Stats | null>(null)\\n\\n// ������?��????��?��\\nexport const requestsAtom = atom<Request[]>([])\\n\\n// ????���??��������\\nexport const searchQueryAtom = atom('')\\n\\n// ��????��??????\\nexport const filtersAtom = atom({\\n  session: '',\\n  provider: '',\\n  model: ''\\n})\\n\\n// Token ��???????��???\\nexport const tokenTrendDataAtom = atom<TokenTrendPoint[]>([])\\n\\n// ��???????��???????��???????\\nexport const trendPeriodAtom = atom(24)\\n\\n// ????????????����|???\\nexport const selectedAnalysisAtom = atom<Analysis | null>(null)\\n\\n// ?��?����???? Tab\\nexport const activeTabAtom = atom<'token' | 'heatmap' | 'timeline' | 'graph' | 'insights'>('token')\\n\\n// Modal ????????????\\nexport const analysisModalOpenAtom = atom(false)\\n\\n// ??��??�㨨????��??��?????��?o?����|?????��??��???\\nexport const refreshCounterAtom = atom(0)\\n\\n// ?��???????��????��??????������?��????��?��\\nexport const filteredRequestsAtom = atom((get) => {\\n  const requests = get(requestsAtom)\\n  const searchQuery = get(searchQueryAtom).toLowerCase()\\n  \\n  if (!searchQuery) return requests\\n  \\n  return requests.filter(req => \\n    req.provider.toLowerCase().includes(searchQuery) ||\\n    req.model.toLowerCase().includes(searchQuery) ||\\n    req.runId.toLowerCase().includes(searchQuery) ||\\n    req.sessionId.toLowerCase().includes(searchQuery)\\n  )\\n})\\n\\n// ?��???????������?��??????��\\nexport const requestCountAtom = atom((get) => {\\n  return get(filteredRequestsAtom).length\\n})\\n\\n// ?��???o?????? atoms\\nexport * from './api'\\nexport * from './charts'\"}}],\"api\":\"openai-completions\",\"provider\":\"bailian\",\"model\":\"qwen3.5-plus\",\"usage\":{\"input\":0,\"output\":0,\"cacheRead\":0,\"cacheWrite\":0,\"totalTokens\":0,\"cost\":{\"input\":0,\"output\":0,\"cacheRead\":0,\"cacheWrite\":0,\"total\":0}},\"stopReason\":\"toolUse\",\"timestamp\":1773114890130},{\"role\":\"toolResult\",\"toolCallId\":\"call03e9e283b76b4161a6b28c27\",\"toolName\":\"edit\",\"content\":[{\"type\":\"text\",\"text\":\"Successfully replaced text in D:\\\\code\\\\request-analyzer\\\\frontend\\\\src\\\\atoms\\\\index.ts.\"}],\"isError\":false,\"timestamp\":1773114899170},{\"role\":\"assistant\",\"content\":[{\"type\":\"thinking\",\"thinking\":\"??��??��????��? api.ts ??-????��????��??����????\",\"thinkingSignature\":\"reasoning_content\"},{\"type\":\"toolCall\",\"id\":\"callc9d348c47aa1424a8e32c5e6\",\"name\":\"edit\",\"arguments\":{\"path\":\"D:\\\\code\\\\request-analyzer\\\\frontend\\\\src\\\\atoms\\\\api.ts\",\"oldText\":\"import { atom } from 'jotai'\\nimport type { Stats, Request, Analysis, TokenTrendPoint } from '../types'\\n\\nconst API_BASE = '/plugins/contextscope/api'\\n\\n// ???��?????��????��???\\nexport const loadStatsAtom = atom(null, async (get, set) => {\\n  try {\\n    const res = await fetch(`${API_BASE}/stats`)\\n    const data = await res.json()\\n    if (data.error) return\\n    \\n    set(statsAtom, data.stats)\\n    set(loadingAtom, false)\\n  } catch (error) {\\n    console.error('Failed to load stats:', error)\\n    set(loadingAtom, false)\\n  }\\n})\\n\\n// ???��??������?��????��?��\\nexport const loadRequestsAtom = atom(null, async (get, set) => {\\n  try {\\n    const filters = get(filtersAtom)\\n    const params = new URLSearchParams({ limit: '50' })\\n    if (filters.session) params.set('sessionId', filters.session)\\n    if (filters.provider) params.set('provider', filters.provider)\\n    if (filters.model) params.set('model', filters.model)\\n\\n    const res = await fetch(`${API_BASE}/requests?${params}`)\\n    const data = await res.json()\\n    if (data.error) return\\n\\n    set(requestsAtom, data.requests)\\n    set(loadingAtom, false)\\n  } catch (error) {\\n    console.error('Failed to load requests:', error)\\n    set(loadingAtom, false)\\n  }\\n})\\n\\n// ???��?? Token ��?????\\nexport const loadTokenTrendAtom = atom(null, async (get, set) => {\\n  try {\\n    const period = get(trendPeriodAtom)\\n    const endTime = Date.now()\\n    const startTime = endTime - (period * 24 * 60 * 60 * 1000)\\n    \\n    const res = await fetch(`${API_BASE}/requests?startTime=${startTime}&endTime=${endTime}&limit=1000`)\\n    const data = await res.json()\\n    if (data.error) return\\n\\n    const reqs: Request[] = data.requests\\n    \\n    // ????��??????????\\n    const hourlyData: Record<number, { input: number; output: number; total: number }> = {}\\n    \\n    reqs.forEach(req => {\\n      const hour = Math.floor(req.timestamp / (60 * 60 * 1000)) * 60 * 60 * 1000\\n      if (!hourlyData[hour]) hourlyData[hour] = { input: 0, output: 0, total: 0 }\\n      hourlyData[hour].input += req.usage?.input || 0\\n      hourlyData[hour].output += req.usage?.output || 0\\n      hourlyData[hour].total += req.usage?.total || 0\\n    })\\n\\n    const sortedHours = Object.keys(hourlyData).map(Number).sort((a, b) => a - b)\\n    const trendData: TokenTrendPoint[] = sortedHours.map(hour => ({\\n      timestamp: hour,\\n      input: hourlyData[hour].input,\\n      output: hourlyData[hour].output,\\n      total: hourlyData[hour].total\\n    }))\\n\\n    set(tokenTrendDataAtom, trendData)\\n  } catch (error) {\\n    console.error('Failed to load token trend:', error)\\n  }\\n})\\n\\n// ???��????????����|???\\nexport const loadAnalysisAtom = atom(null, async (get, set, runId: string) => {\\n  try {\\n    const res = await fetch(`${API_BASE}/analysis?runId=${runId}`)\\n    const result = await res.json()\\n    \\n    if ('error' in result && result.error) {\\n      alert(`Failed: ${result.error}`)\\n      return\\n    }\\n\\n    set(selectedAnalysisAtom, result)\\n    set(analysisModalOpenAtom, true)\\n    set(activeTabAtom, 'token')\\n  } catch (error) {\\n    alert(`Failed: ${error}`)\\n  }\\n})\\n\\n// ??��??��????????��???\\nexport const refreshAllAtom = atom(null, async (get, set) => {\\n  set(refreshCounterAtom, prev => prev + 1)\\n  await Promise.all([\\n    set(loadStatsAtom),\\n    set(loadRequestsAtom),\\n    set(loadTokenTrendAtom)\\n  ])\\n})\\n\\n// ???��?�訨????��\\nexport const clearFiltersAtom = atom(null, (get, set) => {\\n  set(filtersAtom, { session: '', provider: '', model: '' })\\n  set(searchQueryAtom, '')\\n})\\n\\n// ??3��?-?????? Modal\\nexport const closeAnalysisModalAtom = atom(null, (get, set) => {\\n  set(selectedAnalysisAtom, null)\\n  set(analysisModalOpenAtom, false)\\n})\",\"newText\":\"import { atom } from 'jotai'\\nimport type { Request, TokenTrendPoint } from '../types'\\nimport {\\n  loadingAtom,\\n  statsAtom,\\n  requestsAtom,\\n  filtersAtom,\\n  trendPeriodAtom,\\n  tokenTrendDataAtom,\\n  selectedAnalysisAtom,\\n  analysisModalOpenAtom,\\n  activeTabAtom,\\n  refreshCounterAtom,\\n  searchQueryAtom\\n} from './index'\\n\\nconst API_BASE = '/plugins/contextscope/api'\\n\\n// ???��?????��????��???\\nexport const loadStatsAtom = atom(null, async (_get, set) => {\\n  try {\\n    const res = await fetch(`${API_BASE}/stats`)\\n    const data = await res.json()\\n    if (data.error) return\\n    \\n    set(statsAtom, data.stats)\\n    set(loadingAtom, false)\\n  } catch (error) {\\n    console.error('Failed to load stats:', error)\\n    set(loadingAtom, false)\\n  }\\n})\\n\\n// ???��??������?��????��?��\\nexport const loadRequestsAtom = atom(null, async (get, set) => {\\n  try {\\n    const filters = get(filtersAtom)\\n    const params = new URLSearchParams({ limit: '50' })\\n    if (filters.session) params.set('sessionId', filters.session)\\n    if (filters.provider) params.set('provider', filters.provider)\\n    if (filters.model) params.set('model', filters.model)\\n\\n    const res = await fetch(`${API_BASE}/requests?${params}`)\\n    const data = await res.json()\\n    if (data.error) return\\n\\n    set(requestsAtom, data.requests)\\n    set(loadingAtom, false)\\n  } catch (error) {\\n    console.error('Failed to load requests:', error)\\n    set(loadingAtom, false)\\n  }\\n})\\n\\n// ???��?? Token ��?????\\nexport const loadTokenTrendAtom = atom(null, async (get, set) => {\\n  try {\\n    const period = get(trendPeriodAtom)\\n    const endTime = Date.now()\\n    const startTime = endTime - (period * 24 * 60 * 60 * 1000)\\n    \\n    const res = await fetch(`${API_BASE}/requests?startTime=${startTime}&endTime=${endTime}&limit=1000`)\\n    const data = await res.json()\\n    if (data.error) return\\n\\n    const reqs: Request[] = data.requests\\n    \\n    // ????��??????????\\n    const hourlyData: Record<number, { input: number; output: number; total: number }> = {}\\n    \\n    reqs.forEach(req => {\\n      const hour = Math.floor(req.timestamp / (60 * 60 * 1000)) * 60 * 60 * 1000\\n      if (!hourlyData[hour]) hourlyData[hour] = { input: 0, output: 0, total: 0 }\\n      hourlyData[hour].input += req.usage?.input || 0\\n      hourlyData[hour].output += req.usage?.output || 0\\n      hourlyData[hour].total += req.usage?.total || 0\\n    })\\n\\n    const sortedHours = Object.keys(hourlyData).map(Number).sort((a, b) => a - b)\\n    const trendData: TokenTrendPoint[] = sortedHours.map(hour => ({\\n      timestamp: hour,\\n      input: hourlyData[hour].input,\\n      output: hourlyData[hour].output,\\n      total: hourlyData[hour].total\\n    }))\\n\\n    set(tokenTrendDataAtom, trendData)\\n  } catch (error) {\\n    console.error('Failed to load token trend:', error)\\n  }\\n})\\n\\n// ???��????????����|???\\nexport const loadAnalysisAtom = atom(null, async (_get, set, runId: string) => {\\n  try {\\n    const res = await fetch(`${API_BASE}/analysis?runId=${runId}`)\\n    const result = await res.json()\\n    \\n    if ('error' in result && result.error) {\\n      alert(`Failed: ${result.error}`)\\n      return\\n    }\\n\\n    set(selectedAnalysisAtom, result)\\n    set(analysisModalOpenAtom, true)\\n    set(activeTabAtom, 'token')\\n  } catch (error) {\\n    alert(`Failed: ${error}`)\\n  }\\n})\\n\\n// ??��??��????????��???\\nexport const refreshAllAtom = atom(null, async (_get, set) => {\\n  set(refreshCounterAtom, (prev: number) => prev + 1)\\n  await Promise.all([\\n    set(loadStatsAtom),\\n    set(loadRequestsAtom),\\n    set(loadTokenTrendAtom)\\n  ])\\n})\\n\\n// ???��?�訨????��\\nexport const clearFiltersAtom = atom(null, (_get, set) => {\\n  set(filtersAtom, { session: '', provider: '', model: '' })\\n  set(searchQueryAtom, '')\\n})\\n\\n// ??3��?-?????? Modal\\nexport const closeAnalysisModalAtom = atom(null, (_get, set) => {\\n  set(selectedAnalysisAtom, null)\\n  set(analysisModalOpenAtom, false)\\n})\"}}],\"api\":\"openai-completions\",\"provider\":\"bailian\",\"model\":\"qwen3.5-plus\",\"usage\":{\"input\":0,\"output\":0,\"cacheRead\":0,\"cacheWrite\":0,\"totalTokens\":0,\"cost\":{\"input\":0,\"output\":0,\"cacheRead\":0,\"cacheWrite\":0,\"total\":0}},\"stopReason\":\"toolUse\",\"timestamp\":1773114899179},{\"role\":\"toolResult\",\"toolCallId\":\"callc9d348c47aa1424a8e32c5e6\",\"toolName\":\"edit\",\"content\":[{\"type\":\"text\",\"text\":\"Successfully replaced text in D:\\\\code\\\\request-analyzer\\\\frontend\\\\src\\\\atoms\\\\api.ts.\"}],\"isError\":false,\"timestamp\":1773114918060},{\"role\":\"assistant\",\"content\":[{\"type\":\"thinking\",\"thinking\":\"??��??��????��? charts.ts???\",\"thinkingSignature\":\"reasoning_content\"},{\"type\":\"toolCall\",\"id\":\"call4d34955599984ecdb747136d\",\"name\":\"edit\",\"arguments\":{\"path\":\"D:\\\\code\\\\request-analyzer\\\\frontend\\\\src\\\\atoms\\\\charts.ts\",\"oldText\":\"import { atom } from 'jotai'\\nimport type { Stats } from '../types'\\n\\n// Chart.js ???????????��?????��?o?��???��????��????o???\\nexport const tokenChartAtom = atom<any>(null)\\nexport const hourlyChartAtom = atom<any>(null)\\nexport const tokenTrendChartAtom = atom<any>(null)\\n\\n// ??��??��???��?��??��???\\nexport const updateChartsAtom = atom(null, (get, set, stats: Stats) => {\\n  // ��??��????a?-???��???��????��?????????��?????��?��??2?????��????????-��??��??\\n  // ��????��??��??����???????�� atom ??-?-???�� Chart ???????��?��?��???????-??3????\\n  return stats\\n})\\n\\n// ???��?����?????\\nexport const chartConfigAtom = atom({\\n  tokenDistribution: {\\n    type: 'doughnut' as const,\\n    colors: ['#58a6ff', '#3fb950', '#d29922', '#f85149', '#bc8cff', '#36A2EB', '#FFCE56', '#4BC0C0']\\n  },\\n  hourlyDistribution: {\\n    type: 'bar' as const,\\n    color: '#58a6ff'\\n  },\\n  tokenTrend: {\\n    type: 'line' as const,\\n    colors: {\\n      input: '#58a6ff',\\n      output: '#3fb950'\\n    }\\n  }\\n})\",\"newText\":\"im