{"type":"message","id":"69861222","parentId":"4f496026","timestamp":"2026-03-10T16:27:28.250Z","message":{"role":"toolResult","toolCallId":"call_a199e6759084470ea289372c","toolName":"read","content":[{"type":"text","text":"{\r\n  \"name\": \"contextscope\",\r\n  \"version\": \"1.0.0\",\r\n  \"description\": \"ContextScope - visualize API requests, prompts, and token usage\",\r\n  \"type\": \"module\",\r\n  \"main\": \"dist/index.js\",\r\n  \"types\": \"dist/index.d.ts\",\r\n  \"exports\": {\r\n    \".\": {\r\n      \"types\": \"./dist/index.d.ts\",\r\n      \"default\": \"./dist/index.js\"\r\n    }\r\n  },\r\n  \"openclaw\": {\r\n    \"extensions\": [\"./dist/index.js\"]\r\n  },\r\n  \"scripts\": {\r\n    \"build\": \"tsc\",\r\n    \"build:all\": \"npm run build:frontend && npm run build:backend\",\r\n    \"build:backend\": \"tsc\",\r\n    \"build:frontend\": \"cd frontend && npm run build\",\r\n    \"dev\": \"tsc --watch\",\r\n    \"dev:frontend\": \"cd frontend && npm run dev\",\r\n    \"dev:all\": \"concurrently \\\"npm run dev\\\" \\\"npm run dev:frontend\\\"\",\r\n    \"test\": \"vitest\",\r\n    \"preview\": \"cd frontend && npm run preview\"\r\n  },\r\n  \"dependencies\": {\r\n    \"openclaw\": \"^2026.3.8\"\r\n  },\r\n  \"devDependencies\": {\r\n    \"@types/node\": \"^20.0.0\",\r\n    \"concurrently\": \"^9.0.0\",\r\n    \"typescript\": \"^5.0.0\",\r\n    \"vitest\": \"^1.0.0\"\r\n  },\r\n  \"keywords\": [\r\n    \"contextscope\",\r\n    \"api-monitoring\",\r\n    \"token-usage\",\r\n    \"prompt-analysis\",\r\n    \"request-analysis\",\r\n    \"llm-analytics\"\r\n  ],\r\n  \"author\": \"Your Name\",\r\n  \"license\": \"MIT\",\r\n  \"repository\": {\r\n    \"type\": \"git\",\r\n    \"url\": \"https://github.com/yourname/contextscope\"\r\n  }\r\n}\r\n"}],"isError":false,"timestamp":1773160047977}}
