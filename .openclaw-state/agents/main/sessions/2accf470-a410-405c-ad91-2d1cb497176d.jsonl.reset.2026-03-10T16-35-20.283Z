\":4,\\\"endedAt\\\":1773160079402},{\\\"kind\\\":\\\"spawn\\\",\\\"parentRunId\\\":\\\"d43888a1-d47d-4402-97fe-ad582d8b1450\\\",\\\"childRunId\\\":\\\"d30be165-ce30-4176-87e6-2789e7351308\\\",\\\"parentSessionId\\\":\\\"2accf470-a410-405c-ad91-2d1cb497176d\\\",\\\"parentSessionKey\\\":\\\"agent:main:main\\\",\\\"childSessionKey\\\":\\\"agent:main:subagent:f7e9ca4c-262c-476f-a252-a8dc71d756ac\\\",\\\"runtime\\\":\\\"subagent\\\",\\\"mode\\\":\\\"run\\\",\\\"toolCallId\\\":\\\"call_1d388309ae7c48a48a338935\\\",\\\"timestamp\\\":1773159957646,\\\"metadata\\\":{\\\"agentId\\\":\\\"main\\\",\\\"targetSessionKey\\\":\\\"agent:main:subagent:f7e9ca4c-262c-476f-a252-a8dc71d756ac\\\",\\\"reason\\\":\\\"subagent-complete\\\",\\\"targetKind\\\":\\\"subagent\\\"},\\\"outcome\\\":\\\"success\\\",\\\"id\\\":3,\\\"endedAt\\\":1773160098284},{\\\"kind\\\":\\\"spawn\\\",\\\"parentRunId\\\":\\\"d43888a1-d47d-4402-97fe-ad582d8b1450\\\",\\\"childRunId\\\":\\\"d9fb5801-eb4b-40f9-83b4-290330b572a8\\\",\\\"parentSessionId\\\":\\\"2accf470-a410-405c-ad91-2d1cb497176d\\\",\\\"parentSessionKey\\\":\\\"agent:main:main\\\",\\\"childSessionKey\\\":\\\"agent:main:subagent:fbae7b89-32ee-41d9-a888-8a7ab241fbc1\\\",\\\"runtime\\\":\\\"subagent\\\",\\\"mode\\\":\\\"run\\\",\\\"toolCallId\\\":\\\"call_45a5cd891daf47f7a9b4ebc0\\\",\\\"timestamp\\\":1773159956991,\\\"metadata\\\":{\\\"agentId\\\":\\\"main\\\",\\\"targetSessionKey\\\":\\\"agent:main:subagent:fbae7b89-32ee-41d9-a888-8a7ab241fbc1\\\",\\\"reason\\\":\\\"subagent-complete\\\",\\\"targetKind\\\":\\\"subagent\\\"},\\\"outcome\\\":\\\"success\\\",\\\"id\\\":2,\\\"endedAt\\\":1773160033750},{\\\"kind\\\":\\\"spawn\\\",\\\"parentRunId\\\":\\\"d43888a1-d47d-4402-97fe-ad582d8b1450\\\",\\\"childRunId\\\":\\\"03ac5510-4382-4c21-adbc-990bd26288eb\\\",\\\"parentSessionId\\\":\\\"2accf470-a410-405c-ad91-2d1cb497176d\\\",\\\"parentSessionKey\\\":\\\"agent:main:main\\\",\\\"childSessionKey\\\":\\\"agent:main:subagent:629cb399-5cce-43a5-a58a-55cfe9d4b9cd\\\",\\\"runtime\\\":\\\"subagent\\\",\\\"mode\\\":\\\"run\\\",\\\"toolCallId\\\":\\\"call_4359ab84635f49a7bef83d12\\\",\\\"timestamp\\\":1773159956280,\\\"metadata\\\":{\\\"agentId\\\":\\\"main\\\",\\\"targetSessionKey\\\":\\\"agent:main:subagent:629cb399-5cce-43a5-a58a-55cfe9d4b9cd\\\",\\\"reason\\\":\\\"subagent-complete\\\",\\\"targetKind\\\":\\\"subagent\\\"},\\\"outcome\\\":\\\"success\\\",\\\"id\\\":1,\\\"endedAt\\\":1773160074964}],\\\"total\\\":5,\\\"filters\\\":{\\\"limit\\\":20,\\\"offset\\\":0}}\",\"cwd\":\"C:\\\\Users\\\\10906\\\\.openclaw\\\\workspace\"}},\"metadata\":{\"agentId\":\"main\"},\"id\":71},{\"runId\":\"04dccc2e-c7c8-4172-b924-3346343f6149\",\"sessionId\":\"2accf470-a410-405c-ad91-2d1cb497176d\",\"sessionKey\":\"agent:main:main\",\"toolName\":\"exec\",\"toolCallId\":\"call_0a80b540210b4fc983f45e2f\",\"timestamp\":1773160240687,\"startedAt\":1773160240305,\"durationMs\":382,\"params\":{\"command\":\"Invoke-WebRequest -Uri \\\"http://127.0.0.1:18789/plugins/contextscope/api/stats\\\" -UseBasicParsing | Select-Object -ExpandProperty Content\"},\"result\":{\"content\":[{\"type\":\"text\",\"text\":\"{\\\"stats\\\":{\\\"totalRequests\\\":69,\\\"todayRequests\\\":29,\\\"weekRequests\\\":69,\\\"averageTokens\\\":0,\\\"totalCost\\\":0,\\\"byProvider\\\":{\\\"bailian\\\":61,\\\"openrouter\\\":2,\\\"anthropic\\\":6},\\\"byModel\\\":{\\\"qwen3.5-plus\\\":61,\\\"anthropic/claude-3.5-sonnet\\\":2,\\\"claude-opus-4-6\\\":6},\\\"hourlyDistribution\\\":[29,0,6,2,0,0,0,0,0,0,0,18,0,0,0,0,1,3,0,0,0,0,0,10]},\\\"storage\\\":{\\\"totalRequests\\\":69,\\\"todayRequests\\\":29,\\\"weekRequests\\\":69,\\\"storageSize\\\":\\\"18.4 MB\\\",\\\"oldestRequest\\\":1773081035652,\\\"newestRequest\\\":1773160240634},\\\"config\\\":{\\\"theme\\\":\\\"dark\\\",\\\"autoRefresh\\\":true,\\\"refreshInterval\\\":5000}}\"}],\"details\":{\"status\":\"completed\",\"exitCode\":0,\"durationMs\":376,\"aggregated\":\"{\\\"stats\\\":{\\\"totalRequests\\\":69,\\\"todayRequests\\\":29,\\\"weekRequests\\\":69,\\\"averageTokens\\\":0,\\\"totalCost\\\":0,\\\"byProvider\\\":{\\\"bailian\\\":61,\\\"openrouter\\\":2,\\\"anthropic\\\":6},\\\"byModel\\\":{\\\"qwen3.5-plus\\\":61,\\\"anthropic/claude-3.5-sonnet\\\":2,\\\"claude-opus-4-6\\\":6},\\\"hourlyDistribution\\\":[29,0,6,2,0,0,0,0,0,0,0,18,0,0,0,0,1,3,0,0,0,0,0,10]},\\\"storage\\\":{\\\"totalRequests\\\":69,\\\"todayRequests\\\":29,\\\"weekRequests\\\":69,\\\"storageSize\\\":\\\"18.4 MB\\\",\\\"oldestRequest\\\":1773081035652,\\\"newestRequest\\\":1773160240634},\\\"config\\\":{\\\"theme\\\":\\\"dark\\\",\\\"autoRefresh\\\":true,\\\"refreshInterval\\\":5000}}\",\"cwd\":\"C:\\\\Users\\\\10906\\\\.openclaw\\\\workspace\"}},\"metadata\":{\"agentId\":\"main\"},\"id\":70},{\"runId\":\"97e40f43-6fab-4eec-a005-3365c659f444\",\"sessionId\":\"a83f887e-f946-4df5-a367-ea8e85d9d602\",\"sessionKey\":\"agent:main:subagent:837950ff-abf3-430b-a50d-166d58677c1e\",\"toolName\":\"web_search\",\"toolCallId\":\"call_50cdfa3577ba4a32bb6497d6\",\"timestamp\":1773160098048,\"startedAt\":1773160088887,\"durationMs\":9161,\"params\":{\"query\":\"Node.js v22 new features 2024 2025 ??��??1??��\",\"count\":10,\"freshness\":\"year\"},\"result\":{\"content\":[{\"type\":\"text\",\"text\":\"{\\n  \\\"query\\\": \\\"Node.js v22 new features 2024 2025 ??��??1??��\\\",\\n  \\\"provider\\\": \\\"perplexity\\\",\\n  \\\"model\\\": \\\"perplexity/sonar-pro\\\",\\n  \\\"tookMs\\\": 9271,\\n  \\\"externalContent\\\": {\\n    \\\"untrusted\\\": true,\\n    \\\"source\\\": \\\"web_search\\\",\\n    \\\"provider\\\": \\\"perplexity\\\",\\n    \\\"wrapped\\\": true\\n  },\\n  \\\"content\\\": \\\"\\\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\\\\\"2ff9bae672ec3964\\\\\\\">>>\\\\nSource: Web Search\\\\n---\\\\nNode.js v22, first released on April 24, 2024, and designated as LTS in 2026, introduces significant enhancements in V8 engine upgrades, testing tools, performance, security, and module support[1][2][5].\\\\n\\\\n### V8 12.4 Engine Upgrades (ES2024 Features)\\\\nNode.js v22 integrates **V8 12.4**, enabling native JavaScript features without transpilation:\\\\n- **Array.fromAsync()**: Converts async iterables (e.g., streams) to arrays cleanly: `await Array.fromAsync(stream)`[1].\\\\n- **Set operations**: Native methods like `union()`, `intersection()`, `difference()`, `symmetricDifference()`, `isSubsetOf()`, and `isSupersetOf()`[1].\\\\n- **Promise.withResolvers()**: Returns `{ promise, resolve, reject }` for deferred promises[1].\\\\n- **Object.groupBy()**: Groups arrays by key function, e.g., `Object.groupBy(items, item => item.type)`[1][2].\\\\nAdditional V8 benefits include faster JIT compilation, improved garbage collection, and reduced cold starts for serverless workloads[2].\\\\n\\\\n### Built-in Test Runner (Production-Ready)\\\\nThe test runner is now stable (no experimental flag), with built-in coverage and **snapshot testing**:\\\\n```\\\\nimport { test, describe } from 'node:test';\\\\ntest('snapshot', (t) => t.assert.snapshot(result));\\\\n```\\\\nRun with `node --test --experimental-test-coverage` for reports (e.g., 94.3% line coverage)[1].\\\\n\\\\n### Performance and Streams\\\\n- **8-15% throughput gains** on web servers vs. v20[1].\\\\n- Improved stream APIs: Better backpressure, `stream.compose()`, and error propagation[2].\\\\n\\\\n### Security and Permissions\\\\n- Enhanced TLS 1.3 and runtime permissions: `node --experimental-permission --allow-fs-read=./config app.js`[2].\\\\n- Security fixes for V8 vulnerabilities (e.g., CVE-2024-6779, CVE-2025-14766) and HTTP/2 crashes (CVE-2025-59465)[3].\\\\n\\\\n### Module and ESM Improvements\\\\n- Stabilized **top-level await** in ESM for cleaner bootstrapping[2].\\\\n- `require(ESM)` support and optimized resolution[1][2].\\\\n- **Hashbang (#!)** mode for executable .js scripts[2].\\\\n\\\\n### Built-in Clients and APIs\\\\n- **Native WebSocket client** (`node:ws` module) for real-time apps, reducing dependencies[2].\\\\n- **fs.glob()** for pattern matching in file system operations[2].\\\\n\\\\n### Native Add-ons and Tools\\\\n- Stable **N-API v10** for ABI-compatible C/C++ modules[2].\\\\n- Better heap snapshots, DevTools integration, and `--report-on-fatalerror` for debugging[2].\\\\n\\\\nFor 2025 updates, v22 includes ongoing security patches (e.g., CVE-2025 series), but no major new features beyond initial release are detailed in current sources[3]. Upgrade guides recommend testing for ESM shifts and permissions[1][2]. Native TypeScript support is experimental[4].\\\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\\\\\"2ff9bae672ec3964\\\\\\\">>>\\\",\\n  \\\"citations\\\": []\\n}\"}],\"details\":{\"query\":\"Node.js v22 new features 2024 2025 ??��??1??��\",\"provider\":\"perplexity\",\"model\":\"perplexity/sonar-pro\",\"tookMs\":9271,\"externalContent\":{\"untrusted\":true,\"source\":\"web_search\",\"provider\":\"perplexity\",\"wrapped\":true},\"content\":\"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"2ff9bae672ec3964\\\">>>\\nSource: Web Search\\n---\\nNode.js v22, first released on April 24, 2024, and designated as LTS in 2026, introduces significant enhancements in V8 engine upgrades, testing tools, performance, security, and module support[1][2][5].\\n\\n### V8 12.4 Engine Upgrades (ES2024 Features)\\nNode.js v22 integrates **V8 12.4**, enabling native JavaScript features without transpilation:\\n- **Array.fromAsync()**: Converts async iterables (e.g., streams) to arrays cleanly: `await Array.fromAsync(stream)`[1].\\n- **Set operations**: Native methods like `union()`, `intersection()`, `difference()`, `symmetricDifference()`, `isSubsetOf()`, and `isSupersetOf()`[1].\\n- **Promise.withResolvers()**: Returns `{ promise, resolve, reject }` for deferred promises[1].\\n- **Object.groupBy()**: Groups arrays by key function, e.g., `Object.groupBy(items, item => item.type)`[1][2].\\nAdditional V8 benefits include faster JIT compilation, improved garbage collection, and reduced cold starts for serverless workloads[2].\\n\\n### Built-in Test Runner (Production-Ready)\\nThe test runner is now stable (no experimental flag), with built-in coverage and **snapshot testing**:\\n```\\nimport { test, describe } from 'node:test';\\ntest('snapshot', (t) => t.assert.snapshot(result));\\n```\\nRun with `node --test --experimental-test-coverage` for reports (e.g., 94.3% line coverage)[1].\\n\\n### Performance and Streams\\n- **8-15% throughput gains** on web servers vs. v20[1].\\n- Improved stream APIs: Better backpressure, `stream.compose()`, and error propagation[2].\\n\\n### Security and Permissions\\n- Enhanced TLS 1.3 and runtime permissions: `node --experimental-permission --allow-fs-read=./config app.js`[2].\\n- Security fixes for V8 vulnerabilities (e.g., CVE-2024-6779, CVE-2025-14766) and HTTP/2 crashes (CVE-2025-59465)[3].\\n\\n### Module and ESM Improvements\\n- Stabilized **top-level await** in ESM for cleaner bootstrapping[2].\\n- `require(ESM)` support and optimized resolution[1][2].\\n- **Hashbang (#!)** mode for executable .js scripts[2].\\n\\n### Built-in Clients and APIs\\n- **Native WebSocket client** (`node:ws` module) for real-time apps, reducing dependencies[2].\\n- **fs.glob()** for pattern matching in file system operations[2].\\n\\n### Native Add-ons and Tools\\n- Stable **N-API v10** for ABI-compatible C/C++ modules[2].\\n- Better heap snapshots, DevTools integration, and `--report-on-fatalerror` for debugging[2].\\n\\nFor 2025 updates, v22 includes ongoing security patches (e.g., CVE-2025 series), but no major new features beyond initial release are detailed in current sources[3]. Upgrade guides recommend testing for ESM shifts and permissions[1][2]. Native TypeScript support is experimental[4].\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\"2ff9bae672ec3964\\\">>>\",\"citations\":[]}},\"metadata\":{\"agentId\":\"main\"},\"id\":69},{\"runId\":\"97e40f43-6fab-4eec-a005-3365c659f444\",\"sessionId\":\"a83f887e-f946-4df5-a367-ea8e85d9d602\",\"sessionKey\":\"agent:main:subagent:837950ff-abf3-430b-a50d-166d58677c1e\",\"toolName\":\"web_search\",\"toolCallId\":\"call_fefaab53f0414fd095748fee\",\"timestamp\":1773160088779,\"startedAt\":1773160081090,\"durationMs\":7689,\"params\":{\"query\":\"OpenClaw GitHub project stars latest release 2025 2026\",\"count\":10,\"freshness\":\"year\"},\"result\":{\"content\":[{\"type\":\"text\",\"text\":\"{\\n  \\\"query\\\": \\\"OpenClaw GitHub project stars latest release 2025 2026\\\",\\n  \\\"provider\\\": \\\"perplexity\\\",\\n  \\\"model\\\": \\\"perplexity/sonar-pro\\\",\\n  \\\"tookMs\\\": 7800,\\n  \\\"externalContent\\\": {\\n    \\\"untrusted\\\": true,\\n    \\\"source\\\": \\\"web_search\\\",\\n    \\\"provider\\\": \\\"perplexity\\\",\\n    \\\"wrapped\\\": true\\n  },\\n  \\\"content\\\": \\\"\\\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\\\\\"07fb22d305c876eb\\\\\\\">>>\\\\nSource: Web Search\\\\n---\\\\n**OpenClaw is the most-starred non-aggregator software project on GitHub, with over 250,000 stars as of early 2026, having surpassed React (243K stars) and Linux (220K stars) in under four months.** [1][2][5]\\\\n\\\\nLaunched in November 2025 by Austrian developer Peter Steinberger as a fully open-source, locally-run AI agent framework, it connects large language models to tools like WhatsApp, Telegram, Discord, and iMessage for tasks such as executing terminal commands, file operations, email handling, and schedule management.[1][3]\\\\n\\\\nIt rapidly gained traction: a 1-hour prototype evolved into the fastest-growing GitHub repository, reaching 175,000+ stars by early 2026 and topping historical lists by overtaking long-standing projects like React (13 years to 240K stars).[1][2][3]\\\\n\\\\nNo specific latest release details for 2025 or 2026 are available in the results; the GitHub organization (github.com/openclaw) lists 22 repositories but lacks version info here.[4] A January 2026 security incident (\\\\\\\"ClawHavoc\\\\\\\") involved malware via disguised skill packages, prompting restrictions by some tech firms.[1]\\\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\\\\\"07fb22d305c876eb\\\\\\\">>>\\\",\\n  \\\"citations\\\": []\\n}\"}],\"details\":{\"query\":\"OpenClaw GitHub project stars latest release 2025 2026\",\"provider\":\"perplexity\",\"model\":\"perplexity/sonar-pro\",\"tookMs\":7800,\"externalContent\":{\"untrusted\":true,\"source\":\"web_search\",\"provider\":\"perplexity\",\"wrapped\":true},\"content\":\"\\n<<<EXTERNAL_UNTRUSTED_CONTENT id=\\\"07fb22d305c876eb\\\">>>\\nSource: Web Search\\n---\\n**OpenClaw is the most-starred non-aggregator software project on GitHub, with over 250,000 stars as of early 2026, having surpassed React (243K stars) and Linux (220K stars) in under four months.** [1][2][5]\\n\\nLaunched in November 2025 by Austrian developer Peter Steinberger as a fully open-source, locally-run AI agent framework, it connects large language models to tools like WhatsApp, Telegram, Discord, and iMessage for tasks such as executing terminal commands, file operations, email handling, and schedule management.[1][3]\\n\\nIt rapidly gained traction: a 1-hour prototype evolved into the fastest-growing GitHub repository, reaching 175,000+ stars by early 2026 and topping historical lists by overtaking long-standing projects like React (13 years to 240K stars).[1][2][3]\\n\\nNo specific latest release details for 2025 or 2026 are available in the results; the GitHub organization (github.com/openclaw) lists 22 repositories but lacks version info here.[4] A January 2026 security incident (\\\"ClawHavoc\\\") involved malware via disguised skill packages, prompting restrictions by some tech firms.[1]\\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\\\"07fb22d305c876eb\\\">>>\",\"citations\":[]}},\"metadata\":{\"agentId\":\"main\"},\"id\":68}],\"total\":10,\"filters\":{\"limit\":10,\"offset\":0}}"}],"details":{"status":"completed","exitCode":0,"durationMs":898,"aggregated":"\\\\r\\\\n|   |   |   |           wkPage.js\\\\r\\\\n|   |   |   |           